# Deck — variáveis de ambiente. Copie pra .env (gitignored) e preencha.

# ── App atual (loopback / acesso pessoal) ───────────────────────────────────
# Token de acesso ao backend WS. Vazio = sem gate (só loopback). O serve-fellow
# gera um forte sozinho se não setado.
COCKPIT_TOKEN=
# Porta do backend (default 7777).
COCKPIT_PORT=7777
# Liga o toggle de bypass (admin + loopback). Default off. NUNCA pra fellows.
COCKPIT_ALLOW_BYPASS=
# "Este deploy é a box do dono" — desacopla o gate de bypass do bind (DR-017).
COCKPIT_LOCAL_ONLY=
# Frontend separado (Vercel) → aponta o WS pro host real do backend.
VITE_WS_URL=

# ── Relay T3 (multi-conta; DR-023) ──────────────────────────────────────────
# Projeto Supabase dedicado deck-relay (NÃO o stack do DFL prod).
VITE_SUPABASE_URL=https://ikxtdssxmcgipyfpwmar.supabase.co
# anon/publishable key (pública por design; vai no bundle do browser).
VITE_SUPABASE_ANON_KEY=
# Relay (server-side): allowlist de emails root (CSV) — NUNCA flag de banco.
COCKPIT_ROOT_EMAILS=
# Relay verifica JWT offline via JWKS do projeto (chave pública).
SUPABASE_JWKS_URL=https://ikxtdssxmcgipyfpwmar.supabase.co/auth/v1/.well-known/jwks.json
# Service role do relay (só no service-path: setar is_admin, marcar code usado).
# NUNCA prefixar com VITE_ (vazaria no bundle). Manter fora do git.
SUPABASE_SERVICE_ROLE_KEY=
