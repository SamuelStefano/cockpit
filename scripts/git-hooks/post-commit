#!/usr/bin/env bash
# Auto-redeploy: ao commitar no main mexendo em server/ ou shared/, reinicia
# backend+agente pra o código novo subir na hora (causa-raiz 2026-06-17: fix no
# main mas processo rodando código de dias atrás). Só no main — commit em feature
# branch NÃO reinicia (senão a box live rodaria código não-revisado).
set -uo pipefail
cd "$(git rev-parse --show-toplevel)" || exit 0

[ "$(git rev-parse --abbrev-ref HEAD)" = "main" ] || exit 0

# Arquivos do último commit; se não há HEAD~1 (commit inicial), trata como tudo.
changed=$(git diff --name-only HEAD~1 HEAD 2>/dev/null || git show --name-only --pretty=format: HEAD)
echo "$changed" | grep -qE '^(server/|shared/)' || exit 0

echo "[post-commit] main tocou server/ — agendando redeploy"
setsid bash scripts/redeploy.sh >>/tmp/cockpit-redeploy.log 2>&1 < /dev/null &
exit 0
